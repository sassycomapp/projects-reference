{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "instructions": ["README.md"],
  "permission": {
    "edit": {
      "*": "ask",
      "**/anvil.yaml": "deny"
    },
    "webfetch": "ask",
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "rm -r -f *": "deny",
      "git reset --hard*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny"
    },
    "external_directory": {
      "C:\\projects\\**": "allow"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny"
      }
    }
  }
}
